---

layout: base.njk
title: Pinkkard Design Blog
---------------------------

<section class="pd-hero pd-section pd-hero--spacious">
  <div class="wrap">
    <span class="pd-pill">Welcome</span>
    <h1 class="pd-display">I am Janekia Pinkard</h1>
    <p class="pd-muted">Web Designer</p>
  </div>
</section>

<section class="posts">
  <div class="wrap wrap--narrow">

```
{% set posts = [] %}
{% for p in collections.all %}
  {% if p.inputPath and ("/posts/" in p.inputPath) %}
    {% set posts = posts.concat([p]) %}
  {% endif %}
{% endfor %}

{% set posts = posts | reverse %}

{% for post in posts %}
  <article class="pd-card post-card pd-hover-raise">

    <p class="post-meta">{{ post.date | fmtDate }}</p>

    <h2 class="post-title">
      <a href="{{ post.url }}">
        {{ post.data.title or post.fileSlug }}
      </a>
    </h2>

    <p class="post-excerpt">
      {{ post.templateContent | striptags | truncate(180) }}
    </p>

    <a href="{{ post.url }}" class="read-more">Read more →</a>

  </article>
{% endfor %}
```

  </div>
</section>
